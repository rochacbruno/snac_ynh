#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source ../settings/scripts/_common.sh
source /usr/share/yunohost/helpers

#=================================================
# RESTORE THE APP MAIN DIR
#=================================================
ynh_script_progression "Restoring the app main directory..."

ynh_restore "$install_dir"

chown -R "$app:www-data" "$install_dir"

# Restore CLI wrapper symlink
ln -sf "$install_dir/snac-admin" /usr/local/bin/snac-admin

#=================================================
# RESTORE THE DATA DIRECTORY
#=================================================
ynh_script_progression "Restoring the data directory..."

ynh_restore "$data_dir"

chown -R "$app:$app" "$data_dir"

#=================================================
# RESTORE SYSTEM CONFIGURATION
#=================================================
ynh_script_progression "Restoring system configurations related to $app..."

ynh_restore "/etc/nginx/conf.d/$domain.d/$app.conf"

# For subpath installs, restore or regenerate the well-known nginx config
if [ "$path" != "/" ]; then
    if [ -f "$YNH_APP_BACKUP_DIR/etc/nginx/conf.d/$domain.d/$app-wellknown.conf" ]; then
        ynh_restore "/etc/nginx/conf.d/$domain.d/$app-wellknown.conf"
    else
        ynh_config_add --template="nginx-wellknown.conf" --destination="/etc/nginx/conf.d/$domain.d/$app-wellknown.conf"
    fi
fi

ynh_restore "/etc/systemd/system/$app.service"
systemctl enable "$app.service" --quiet

mkdir -p "/var/log/$app"
chown "$app:$app" "/var/log/$app"
ynh_restore "/var/log/$app/" || true

yunohost service add "$app" --description="snac2 ActivityPub instance" --log="/var/log/$app/$app.log"

ynh_restore "/etc/logrotate.d/$app"

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting $app's systemd service..."

ynh_systemctl --service="$app" --action="start"

ynh_systemctl --service=nginx --action=reload

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Restoration completed for $app"
