#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source /usr/share/yunohost/helpers

#=================================================
# RETRIEVE ARGUMENTS
#=================================================

install_dir=$(ynh_app_setting_get --key=install_dir)
data_dir=$(ynh_app_setting_get --key=data_dir)

#=================================================
# SPECIFIC GETTERS FOR TOML SHORT KEY
#=================================================

_read_json() {
    local key="$1"
    python3 -c "
import json, sys
with open('$data_dir/server.json') as f:
    data = json.load(f)
v = data.get('$key', '')
if isinstance(v, bool):
    print('true' if v else 'false')
elif isinstance(v, list):
    print(','.join(str(i) for i in v))
else:
    print(v)
"
}

_write_json() {
    local key="$1"
    local value="$2"
    local value_type="$3"  # string, number, boolean, or array
    python3 -c "
import json
with open('$data_dir/server.json') as f:
    data = json.load(f)
key = '$key'
value = '''$value'''
value_type = '$value_type'
if value_type == 'boolean':
    data[key] = value.lower() in ('true', '1', 'yes')
elif value_type == 'number':
    try:
        data[key] = int(value)
    except ValueError:
        data[key] = float(value)
elif value_type == 'array':
    if value.strip():
        data[key] = [s.strip() for s in value.split(',')]
    else:
        data[key] = []
else:
    data[key] = value
with open('$data_dir/server.json', 'w') as f:
    json.dump(data, f, indent=4)
"
}

# Instance settings
get__title() {
    echo "$(_read_json title)"
}
set__title() {
    _write_json title "$title" string
    ynh_app_setting_set --key=title --value="$title"
}

