#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# INITIALIZE AND STORE SETTINGS
#=================================================
ynh_script_progression "Initializing settings..."

# Store admin account name for server.json
admin_account="$admin"
ynh_app_setting_set --key=admin_account --value="$admin_account"

# Compute and store path prefix
compute_path_prefix
ynh_app_setting_set --key=path_prefix --value="$path_prefix"

# Set defaults for all server.json settings
ynh_app_setting_set --key=dbglevel --value=0
ynh_app_setting_set --key=queue_retry_minutes --value=3
ynh_app_setting_set --key=queue_retry_max --value=10
ynh_app_setting_set --key=queue_timeout --value=6
ynh_app_setting_set --key=queue_timeout_2 --value=8
ynh_app_setting_set --key=num_threads --value=8
ynh_app_setting_set --key=def_timeline_entries --value=50
ynh_app_setting_set --key=max_timeline_entries --value=256
ynh_app_setting_set --key=timeline_purge_days --value=120
ynh_app_setting_set --key=local_purge_days --value=0
ynh_app_setting_set --key=min_account_age --value=3600
ynh_app_setting_set --key=short_description --value=""
ynh_app_setting_set --key=cssurls --value=""
ynh_app_setting_set --key=max_attachments --value=4
ynh_app_setting_set --key=max_poll_options --value=8
ynh_app_setting_set --key=max_poll_option_length --value=50
ynh_app_setting_set --key=max_public_entries --value=128
ynh_app_setting_set --key=proxy_media --value=true
ynh_app_setting_set --key=show_instance_timeline --value=false
ynh_app_setting_set --key=strip_exif --value=true
ynh_app_setting_set --key=enable_svg --value=false
ynh_app_setting_set --key=shared_inboxes --value=true
ynh_app_setting_set --key=badlogin_retries --value=5
ynh_app_setting_set --key=badlogin_expire --value=300
ynh_app_setting_set --key=max_failing_days --value=7
ynh_app_setting_set --key=disable_cache --value=false
ynh_app_setting_set --key=disable_email_notifications --value=false
ynh_app_setting_set --key=disable_inbox_collection --value=false
ynh_app_setting_set --key=disable_history --value=false
ynh_app_setting_set --key=disable_block_notifications --value=false
ynh_app_setting_set --key=disable_emojireact --value=false
ynh_app_setting_set --key=disable_notify_webhook --value=false
ynh_app_setting_set --key=strict_public_timelines --value=false
ynh_app_setting_set --key=hide_delete_post_button --value=false
ynh_app_setting_set --key=favicon_url --value=""
ynh_app_setting_set --key=rss_hashtag_poll_hours --value=0
ynh_app_setting_set --key=smtp_url --value=""
ynh_app_setting_set --key=smtp_username --value=""
ynh_app_setting_set --key=smtp_password --value=""

#=================================================
# DOWNLOAD, CHECK AND UNPACK SOURCE
#=================================================
ynh_script_progression "Setting up source files..."

ynh_setup_source --dest_dir="$install_dir/src"

#=================================================
# COMPILE SNAC2
#=================================================
ynh_script_progression "Compiling snac2 (this may take a moment)..."

pushd "$install_dir/src"
    make LDFLAGS=-lrt 2>&1
popd

cp "$install_dir/src/snac" "$install_dir/snac"
chmod 755 "$install_dir/snac"
rm -rf "$install_dir/src"

chown -R "$app:www-data" "$install_dir"

#=================================================
# GENERATE CONFIGURATION
#=================================================
ynh_script_progression "Adding $app's configuration files..."

mkdir -p "$data_dir"
ynh_config_add --template="server.json" --destination="$data_dir/server.json"
chmod 600 "$data_dir/server.json"
chown "$app:$app" "$data_dir/server.json"

#=================================================
# CREATE ADMIN USER
#=================================================
ynh_script_progression "Creating admin user..."

printf '%s\n%s\n' "$password" "$admin" | "$install_dir/snac" adduser "$data_dir" "$admin" 2>&1

chown -R "$app:$app" "$data_dir"

#=================================================
# SYSTEM CONFIGURATION
#=================================================
ynh_script_progression "Adding system configurations related to $app..."

ynh_config_add_nginx

ynh_config_add_systemd

mkdir -p "/var/log/$app"
chown "$app:$app" "/var/log/$app"

yunohost service add "$app" --description="snac2 ActivityPub instance" --log="/var/log/$app/$app.log"

ynh_config_add_logrotate

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting $app's systemd service..."

ynh_systemctl --service="$app" --action="start"

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Installation of $app completed"
