#!/bin/bash

#=================================================
# IMPORT GENERIC HELPERS
#=================================================

source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# STOP SYSTEMD SERVICE
#=================================================
ynh_script_progression "Stopping $app's systemd service..."

ynh_systemctl --service="$app" --action="stop"

#=================================================
# ENSURE DOWNWARD COMPATIBILITY
#=================================================
ynh_script_progression "Ensuring downward compatibility..."

# Compute and store path prefix if not already set
compute_path_prefix
ynh_app_setting_set_default --key=path_prefix --value="$path_prefix"
ynh_app_setting_set_default --key=admin_account --value="$admin"

# Defaults for all server.json settings
ynh_app_setting_set_default --key=dbglevel --value=0
ynh_app_setting_set_default --key=queue_retry_minutes --value=3
ynh_app_setting_set_default --key=queue_retry_max --value=10
ynh_app_setting_set_default --key=queue_timeout --value=6
ynh_app_setting_set_default --key=queue_timeout_2 --value=8
ynh_app_setting_set_default --key=num_threads --value=8
ynh_app_setting_set_default --key=def_timeline_entries --value=50
ynh_app_setting_set_default --key=max_timeline_entries --value=256
ynh_app_setting_set_default --key=timeline_purge_days --value=120
ynh_app_setting_set_default --key=local_purge_days --value=0
ynh_app_setting_set_default --key=min_account_age --value=3600
ynh_app_setting_set_default --key=admin_email --value=""
ynh_app_setting_set_default --key=title --value="snac2"
ynh_app_setting_set_default --key=short_description --value=""
ynh_app_setting_set_default --key=cssurls --value=""
ynh_app_setting_set_default --key=max_attachments --value=4
ynh_app_setting_set_default --key=max_poll_options --value=8
ynh_app_setting_set_default --key=max_poll_option_length --value=50
ynh_app_setting_set_default --key=max_public_entries --value=128
ynh_app_setting_set_default --key=proxy_media --value=false
ynh_app_setting_set_default --key=show_instance_timeline --value=false
ynh_app_setting_set_default --key=strip_exif --value=false
ynh_app_setting_set_default --key=enable_svg --value=false
ynh_app_setting_set_default --key=shared_inboxes --value=true
ynh_app_setting_set_default --key=badlogin_retries --value=5
ynh_app_setting_set_default --key=badlogin_expire --value=300
ynh_app_setting_set_default --key=max_failing_days --value=7
ynh_app_setting_set_default --key=disable_cache --value=false
ynh_app_setting_set_default --key=disable_email_notifications --value=false
ynh_app_setting_set_default --key=disable_inbox_collection --value=false
ynh_app_setting_set_default --key=disable_history --value=false
ynh_app_setting_set_default --key=disable_block_notifications --value=false
ynh_app_setting_set_default --key=disable_emojireact --value=false
ynh_app_setting_set_default --key=disable_notify_webhook --value=false
ynh_app_setting_set_default --key=strict_public_timelines --value=false
ynh_app_setting_set_default --key=hide_delete_post_button --value=false
ynh_app_setting_set_default --key=favicon_url --value=""
ynh_app_setting_set_default --key=rss_hashtag_poll_hours --value=0
ynh_app_setting_set_default --key=smtp_url --value=""
ynh_app_setting_set_default --key=smtp_username --value=""
ynh_app_setting_set_default --key=smtp_password --value=""

#=================================================
# DOWNLOAD, CHECK AND UNPACK SOURCE
#=================================================
ynh_script_progression "Upgrading source files..."

ynh_setup_source --dest_dir="$install_dir/src" --full_replace

#=================================================
# COMPILE SNAC2
#=================================================
ynh_script_progression "Compiling snac2 (this may take a moment)..."

pushd "$install_dir/src"
    make LDFLAGS=-lrt 2>&1
popd

cp "$install_dir/src/snac" "$install_dir/snac"
chmod 755 "$install_dir/snac"
ynh_safe_rm "$install_dir/src"

# Install CLI wrapper script
ynh_config_add --template="snac-admin" --destination="$install_dir/snac-admin"
chmod 755 "$install_dir/snac-admin"
ln -sf "$install_dir/snac-admin" /usr/local/bin/snac-admin

chown -R "$app:www-data" "$install_dir"

#=================================================
# UPDATE CONFIGURATION
#=================================================
ynh_script_progression "Updating $app's configuration files..."

# Load all settings into bash variables for template substitution
load_server_settings

ynh_config_add --template="server.json" --destination="$data_dir/server.json"
chmod 600 "$data_dir/server.json"
chown "$app:$app" "$data_dir/server.json"

#=================================================
# RUN SNAC UPGRADE
#=================================================
ynh_script_progression "Running snac2 data upgrade..."

"$install_dir/snac" upgrade "$data_dir" 2>&1 || true

chown -R "$app:$app" "$data_dir"

#=================================================
# REAPPLY SYSTEM CONFIGURATION
#=================================================
ynh_script_progression "Upgrading system configurations related to $app..."

ynh_config_add_nginx

# For subpath installs, add global well-known/API locations needed for federation
if [ "$path" != "/" ]; then
    ynh_config_add --template="nginx-wellknown.conf" --destination="/etc/nginx/conf.d/$domain.d/$app-wellknown.conf"
fi

ynh_config_add_systemd

mkdir -p "/var/log/$app"
chown "$app:$app" "/var/log/$app"

yunohost service add "$app" --description="snac2 ActivityPub instance" --log="/var/log/$app/$app.log"

ynh_config_add_logrotate

#=================================================
# START SYSTEMD SERVICE
#=================================================
ynh_script_progression "Starting $app's systemd service..."

ynh_systemctl --service="$app" --action="start"

#=================================================
# END OF SCRIPT
#=================================================

ynh_script_progression "Upgrade of $app completed"
